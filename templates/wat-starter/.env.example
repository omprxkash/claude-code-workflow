# Copy this file to .env and fill in your real keys.
# .env is gitignored — never commit real credentials.

# Anthropic (if a tool calls the API directly)
ANTHROPIC_API_KEY=<YOUR_API_KEY>

# Research / search provider
RESEARCH_API_KEY=<YOUR_API_KEY>

# Image generation provider (if used)
IMAGE_API_KEY=<YOUR_API_KEY>

# Email delivery (e.g. Gmail / SMTP)
EMAIL_USER=<YOUR_EMAIL>
EMAIL_APP_PASSWORD=<YOUR_APP_PASSWORD>

# Any other service your tools need:
# SHEETS_CREDENTIALS=<PATH_OR_KEY>
